# ============================================
#  Flora Luxe — Переменные окружения
#  Скопируйте: cp .env.example .env
#  Заполните .env своими значениями
# ============================================

# -- Django --
SECRET_KEY=your-very-long-secret-key-here-at-least-50-chars
DJANGO_DEBUG=False

# Хосты: через запятую (без пробелов)
DJANGO_ALLOWED_HOSTS=.railway.app,.up.railway.app

# CSRF — через запятую
CSRF_TRUSTED_ORIGINS=https://*.railway.app,https://*.up.railway.app

# -- База данных (оставьте пустым для SQLite) --
DATABASE_URL=postgres://user:password@host:5432/dbname

# -- Google OAuth (опционально) --
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -- Payme (платёжная система) --
PAYME_SECRET=your-payme-test-or-production-key
PAYME_MERCHANT_ID=your-payme-merchant-id

# -- Click (платёжная система) --
CLICK_SERVICE_ID=your-click-service-id
CLICK_MERCHANT_ID=your-click-merchant-id

# -- OpenAI (опционально — для AI чата) --
OPENAI_API_KEY=

# -- Email (опционально) --
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@floraluxe.uz
